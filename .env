# ─────────────────────────────────────────────────────────────────────────────
# Transcript Bot — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to Git!
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram API ──────────────────────────────────────────────────────────────
# Get from https://my.telegram.org/apps
API_ID=23264133
API_HASH=945e5b76ce8550bebbeeaf5599e7ce58

# Get from @BotFather on Telegram
BOT_TOKEN=8525723495:AAF8HRW99AhOWnVRbeObbEognyzFEJIhyco

# ── Owner ─────────────────────────────────────────────────────────────────────
# Your Telegram numeric user ID (use @userinfobot to find it)
OWNER_ID=6883111123

# Your Telegram username (shown in access denied messages)
OWNER_USERNAME=@Eren_Yeager_76

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local MongoDB (default)
MONGO_URI=mongodb://localhost:27017

# MongoDB Atlas (cloud) example:
# MONGO_URI=c9LydqfbYIXjwh6h@cluster0.nfhcfqo.mongodb.net

# Database name
DB_NAME=transcript_bot

# ── Whisper ───────────────────────────────────────────────────────────────────
# Model size: tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL=large-v3

# Device: "cpu" or "cuda" (NVIDIA GPU)
WHISPER_DEVICE=cpu

# Compute type: "int8" (fast, CPU), "float16" (GPU), "float32" (slow, CPU)
WHISPER_COMPUTE_TYPE=int8

# ── Processing ────────────────────────────────────────────────────────────────
# Maximum file size in MB (default: 2048 = 2GB)
MAX_FILE_SIZE_MB=2048

# Number of concurrent transcription jobs
MAX_CONCURRENT_JOBS=2
